  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "node scripts/start.js",
    "start:pm2": "pm2-runtime ecosystem.config.js",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate-env": "node scripts/validate-env.js",
    "healthcheck": "node scripts/healthcheck.js",
    "smoke-test": "node scripts/smoke-test.js",
    "deploy:check": "npm run validate-env && npm run type-check && npm run test -- --runInBand && npm run build",
    "docker:build": "docker build -t internhub .",
    "docker:run": "docker run -p 3000:3000 --env-file .env internhub",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "seed": "ts-node --project tsconfig.seed.json scripts/seed.ts",
    "migrate": "ts-node --project tsconfig.seed.json scripts/migrate.ts",
    "backup": "ts-node --project tsconfig.seed.json scripts/backup.ts",
    "postinstall": "prisma generate"
  },
